    "headerHeightMobile": "56px",
    "contentMax": "1320px",
    "contentPadding": "20px",
    "contentPaddingMobile": "16px",
    "sidebarWidth": "240px",
    "iconSm": "16px",
    "iconMd": "20px",
    "iconLg": "24px",
    "iconXl": "32px",
    "avatarSm": "32px",
    "avatarMd": "44px",
    "avatarLg": "52px",
    "avatarXl": "64px",
    "thumbnailSm": "48px",
    "thumbnailMd": "64px",
    "thumbnailLg": "72px",
    "thumbnailXl": "80px",
    "thumbnailXxl": "100px",
    "inputHeight": "44px",
    "inputHeightSm": "36px",
    "buttonHeight": "44px",
    "buttonHeightSm": "36px",
    "buttonMinWidth": "180px",
    "touchTarget": "44px",
    "drawerWidth": "380px",
    "drawerWidthMobile": "320px",
    "modalWidth": "480px",
    "modalWidthLg": "640px",
    "formMaxWidth": "440px",
    "formMaxWidthLg": "560px",
    "cardMinWidth": "200px",
    "cardMaxWidth": "300px"
  },
  "borders": {
    "width": "1px",
    "widthMd": "2px"
  },
  "radii": {
    "none": "0",
    "sm": "4px",
    "DEFAULT": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "2xl": "20px",
    "full": "9999px"
  },
  "shadows": {
    "none": "none",
    "sm": "0 1px 2px 0 rgba(10, 25, 48, 0.04)",
    "DEFAULT": "0 1px 3px 0 rgba(10, 25, 48, 0.05), 0 1px 2px -1px rgba(10, 25, 48, 0.04)",
    "md": "0 4px 6px -1px rgba(10, 25, 48, 0.06), 0 2px 4px -2px rgba(10, 25, 48, 0.04)",
    "lg": "0 10px 15px -3px rgba(10, 25, 48, 0.08), 0 4px 6px -4px rgba(10, 25, 48, 0.04)"
  },
  "transitions": {
    "fast": "120ms ease",
    "base": "180ms ease",
    "slow": "280ms ease"
  },
  "layout": {
    "productGridColumns": {
      "mobile": 2,
      "tablet": 3,
      "desktop": 4
    },
    "sidebarWidth": "240px",
    "headerStyle": "sticky",
    "footerColumns": 4,
    "categoryDisplayMode": "sidebar-left"
  },
  "components": {
    "buttons": {
      "borderRadius": "md",
      "textTransform": "none",
      "fontWeight": 600,
      "padding": "12px 28px"
    },
    "cards": {
      "borderRadius": "md",
      "shadow": "none",
      "hoverShadow": "md",
      "border": false
    },
    "badges": {
      "borderRadius": "sm",
      "textTransform": "uppercase",
      "fontSize": "0.7rem",
      "fontWeight": 700
    },
    "inputs": {
      "borderRadius": "sm",
      "borderColor": "border",
      "focusRing": "accent"
    }
  }
}
