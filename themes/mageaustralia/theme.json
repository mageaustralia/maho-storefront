    "2.5": "10px",
    "3": "12px",
    "3.5": "14px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "9": "36px",
    "10": "40px",
    "11": "44px",
    "12": "48px",
    "14": "56px",
    "16": "64px",
    "20": "80px",
    "24": "96px",
    "32": "128px"
  },
  "breakpoints": {
    "sm": "480px",
    "md": "640px",
    "lg": "768px",
    "xl": "1024px",
    "2xl": "1280px"
