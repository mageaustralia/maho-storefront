{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Mageaustralia",
  "description": "Stripe-light aesthetic \u2014 clean white canvas, Inter typography, indigo accent, generous whitespace. The brand site for Mageaustralia's commercial Maho extensions.",
  "colors": {
    "primary": "#0a1930",
    "primaryLight": "#1a2a44",
    "accent": "#5850ec",
    "accentHover": "#4338ca",
    "accentLight": "#eef2ff",
    "success": "#059669",
    "successBg": "#ecfdf5",
    "error": "#dc2626",
    "errorBg": "#fef2f2",
    "sale": "#dc2626",
    "outOfStock": "#9ca3af",
    "text": "#0a1930",
    "textSecondary": "#475569",
    "textMuted": "#94a3b8",
    "border": "#e2e8f0",
    "borderLight": "#f1f5f9",
    "bg": "#ffffff",
    "bgSubtle": "#fafbfc",
    "bgMuted": "#f1f5f9",
    "bgOverlay": "rgba(10, 25, 48, 0.04)",
    "white": "#ffffff",
    "black": "#000000",
    "overlay": "rgba(10, 25, 48, 0.5)",
    "overlayLight": "rgba(10, 25, 48, 0.25)"
  },
  "fonts": {
    "sans": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace",
    "heading": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
  },
  "typography": {
    "baseFontSize": "16px",
    "baseLineHeight": 1.7,
    "h1Size": "2.75rem",
    "h2Size": "2rem",
    "h3Size": "1.5rem",
    "h4Size": "1.25rem",
    "letterSpacing": "-0.015em",
    "headingWeight": 600,
    "bodyWeight": 400,
    "fontSizeXs": "11px",
    "fontSizeXxs": "12px",
    "fontSizeSm": "13px",
    "fontSizeBase": "15px",
    "fontSizeMd": "16px",
    "fontSizeLg": "18px",
    "fontSizeXl": "20px",
    "fontSizeXxl": "22px",
    "fontSize2xl": "26px",
    "fontSize2xlPlus": "30px",
    "fontSize3xl": "36px",
    "fontSize4xl": "44px",
    "fontSize5xl": "56px"
