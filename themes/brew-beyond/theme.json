{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "Brew & Beyond",
  "description": "Warm, artisanal coffee aesthetic with earth tones and craft sensibility",
  "colors": {
    "primary": "#2c1810",
    "primaryLight": "#3d2316",
    "accent": "#c9a86c",
    "accentHover": "#b8944f",
    "accentLight": "#faf7f2",
    "success": "#166534",
    "successBg": "#dcfce7",
    "error": "#dc2626",
    "errorBg": "#fee2e2",
    "sale": "#b91c1c",
    "outOfStock": "#78716c",
    "text": "#1c1917",
    "textSecondary": "#57534e",
    "textMuted": "#a8a29e",
    "border": "#e7e5e4",
    "borderLight": "#f5f5f4",
    "bg": "#ffffff",
    "bgSubtle": "#fafaf9",
    "bgMuted": "#f5f5f4",
    "bgOverlay": "rgba(28, 25, 23, 0.04)",
    "white": "#ffffff",
    "black": "#000000",
    "overlay": "rgba(28, 25, 23, 0.5)",
    "overlayLight": "rgba(0, 0, 0, 0.4)"
  },
  "fonts": {
    "sans": "'Lora', Georgia, serif",
    "mono": "ui-monospace, SFMono-Regular, 'SF Mono', Menlo, Consolas, monospace",
    "heading": "'Playfair Display', Georgia, serif",
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Playfair+Display:wght@400;500;600;700;800&display=swap"
  },
  "typography": {
    "baseFontSize": "16px",
    "baseLineHeight": 1.7,
    "h1Size": "2.5rem",
    "h2Size": "1.75rem",
    "h3Size": "1.375rem",
    "h4Size": "1.125rem",
    "letterSpacing": "0",
    "headingWeight": 600,
    "bodyWeight": 400,
    "fontSizeXs": "11px",
    "fontSizeXxs": "12px",
    "fontSizeSm": "13px",
    "fontSizeBase": "15px",
    "fontSizeMd": "16px",
    "fontSizeLg": "18px",
    "fontSizeXl": "20px",
    "fontSizeXxl": "22px",
