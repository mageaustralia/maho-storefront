  "sizes": {
    "headerHeight": "64px",
    "headerHeightMobile": "56px",
    "contentMax": "1280px",
    "contentPadding": "24px",
    "contentPaddingMobile": "16px",
    "sidebarWidth": "260px",
    "iconSm": "16px",
    "iconMd": "20px",
    "iconLg": "24px",
    "iconXl": "32px",
    "avatarSm": "32px",
    "avatarMd": "44px",
    "avatarLg": "52px",
    "avatarXl": "64px",
    "thumbnailSm": "48px",
    "thumbnailMd": "64px",
    "thumbnailLg": "72px",
    "thumbnailXl": "80px",
    "thumbnailXxl": "100px",
    "inputHeight": "48px",
    "inputHeightSm": "40px",
    "buttonHeight": "48px",
    "buttonHeightSm": "40px",
    "buttonMinWidth": "160px",
    "touchTarget": "44px",
    "drawerWidth": "400px",
    "drawerWidthMobile": "320px",
    "modalWidth": "480px",
    "modalWidthLg": "640px",
    "formMaxWidth": "440px",
    "formMaxWidthLg": "560px",
    "cardMinWidth": "200px",
    "cardMaxWidth": "300px"
  },
  "borders": {
    "width": "1px",
    "widthMd": "2px"
  },
  "radii": {
    "xs": "2px",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "2xl": "16px",
    "full": "9999px"
  },
  "shadows": {
    "xs": "0 1px 2px rgba(28, 25, 23, 0.04)",
    "sm": "0 2px 4px rgba(28, 25, 23, 0.05)",
    "md": "0 4px 12px rgba(28, 25, 23, 0.08)",
    "lg": "0 8px 24px rgba(28, 25, 23, 0.1)",
    "xl": "0 16px 48px rgba(28, 25, 23, 0.12)"
  },
  "transitions": {
    "fast": "120ms ease",
    "base": "200ms ease",
    "slow": "300ms ease"
  },
  "layout": {
    "productGridColumns": { "mobile": 2, "tablet": 3, "desktop": 4 },
    "sidebarWidth": "260px",
    "headerStyle": "sticky",
    "footerColumns": 3,
    "categoryDisplayMode": "sidebar-left"
  },
  "components": {
    "buttons": {
      "borderRadius": "sm",
      "textTransform": "none",
      "fontWeight": 600,
      "padding": "14px 32px"
    },
    "cards": {
      "borderRadius": "md",
      "shadow": "xs",
      "hoverShadow": "md",
      "border": true
    },
    "badges": {
      "borderRadius": "xs",
      "textTransform": "uppercase",
      "fontSize": "0.65rem",
      "fontWeight": 600
    },
    "inputs": {
      "borderRadius": "sm",
      "borderColor": "border",
      "focusRing": "accent"
    }
  }
