{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "name": "TechZone",
  "description": "Modern tech store with sharp corners, blue accent, and clean utility aesthetic",
  "colors": {
    "primary": "#0f172a",
    "primaryLight": "#1e293b",
    "accent": "#3b82f6",
    "accentHover": "#2563eb",
    "accentLight": "#eff6ff",
    "success": "#10b981",
    "successBg": "#ecfdf5",
    "error": "#ef4444",
    "errorBg": "#fef2f2",
    "sale": "#ef4444",
    "outOfStock": "#94a3b8",
    "text": "#0f172a",
    "textSecondary": "#475569",
    "textMuted": "#94a3b8",
    "border": "#e2e8f0",
    "borderLight": "#f1f5f9",
    "bg": "#ffffff",
    "bgSubtle": "#f8fafc",
    "bgMuted": "#f1f5f9",
    "bgOverlay": "rgba(15, 23, 42, 0.04)",
    "white": "#ffffff",
    "black": "#000000",
    "overlay": "rgba(15, 23, 42, 0.5)",
    "overlayLight": "rgba(0, 0, 0, 0.4)"
  },
  "fonts": {
    "sans": "'Inter', -apple-system, BlinkMacSystemFont, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, SFMono-Regular, monospace",
    "heading": "'Space Grotesk', -apple-system, BlinkMacSystemFont, sans-serif",
    "googleFontsImport": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&display=swap"
  },
  "typography": {
    "baseFontSize": "15px",
    "baseLineHeight": 1.6,
    "h1Size": "2.25rem",
    "h2Size": "1.625rem",
    "h3Size": "1.25rem",
    "h4Size": "1.125rem",
    "letterSpacing": "-0.02em",
    "headingWeight": 700,
    "bodyWeight": 400,
    "fontSizeXs": "11px",
    "fontSizeXxs": "12px",
    "fontSizeSm": "13px",
    "fontSizeBase": "14px",
    "fontSizeMd": "16px",
    "fontSizeLg": "18px",
    "fontSizeXl": "20px",
    "fontSizeXxl": "22px",
    "fontSize2xl": "24px",
    "fontSize2xlPlus": "26px",
    "fontSize3xl": "28px",
    "fontSize4xl": "32px",
    "fontSize5xl": "36px"
  },
  "space": {
    "0": "0",
    "px": "1px",
    "0.5": "2px",
    "1": "4px",
    "1.5": "6px",
    "2": "8px",
    "2.5": "10px",
    "3": "12px",
    "3.5": "14px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "7": "28px",
    "8": "32px",
    "9": "36px",
    "10": "40px",
    "11": "44px",
    "12": "48px",
    "14": "56px",
    "16": "64px",
    "20": "80px",
    "24": "96px"
  },
  "breakpoints": {
    "sm": "480px",
    "md": "640px",
    "lg": "768px",
    "xl": "1024px",
    "2xl": "1280px"
  },
  "sizes": {
    "headerHeight": "60px",
    "headerHeightMobile": "56px",
    "contentMax": "1320px",
    "contentPadding": "20px",
    "contentPaddingMobile": "16px",
    "sidebarWidth": "240px",
    "iconSm": "16px",
    "iconMd": "20px",
    "iconLg": "24px",
    "iconXl": "32px",
    "avatarSm": "32px",
    "avatarMd": "44px",
    "avatarLg": "52px",
    "avatarXl": "64px",
    "thumbnailSm": "48px",
    "thumbnailMd": "64px",
    "thumbnailLg": "72px",
    "thumbnailXl": "80px",
    "thumbnailXxl": "100px",
    "inputHeight": "44px",
    "inputHeightSm": "36px",
    "buttonHeight": "44px",
    "buttonHeightSm": "36px",
    "buttonMinWidth": "180px",
    "touchTarget": "44px",
    "drawerWidth": "380px",
    "drawerWidthMobile": "320px",
    "modalWidth": "480px",
    "modalWidthLg": "640px",
    "formMaxWidth": "440px",
    "formMaxWidthLg": "560px",
    "cardMinWidth": "200px",
    "cardMaxWidth": "300px"
  },
  "borders": {
    "width": "1px",
    "widthMd": "2px"
  },
  "radii": {
    "xs": "2px",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "10px",
    "2xl": "12px",
    "full": "9999px"
  },
  "shadows": {
    "xs": "0 1px 2px rgba(15, 23, 42, 0.04)",
    "sm": "0 2px 4px rgba(15, 23, 42, 0.06)",
    "md": "0 4px 12px rgba(15, 23, 42, 0.08)",
    "lg": "0 8px 24px rgba(15, 23, 42, 0.1)",
    "xl": "0 16px 48px rgba(15, 23, 42, 0.12)"
  },
  "transitions": {
    "fast": "120ms ease",
    "base": "180ms ease",
    "slow": "280ms ease"
  },
  "layout": {
    "productGridColumns": { "mobile": 2, "tablet": 3, "desktop": 3 },
    "sidebarWidth": "240px",
    "headerStyle": "sticky",
    "footerColumns": 4,
    "categoryDisplayMode": "sidebar-left"
  },
  "components": {
    "buttons": {
      "borderRadius": "sm",
      "textTransform": "none",
      "fontWeight": 600,
      "padding": "12px 28px"
    },
    "cards": {
      "borderRadius": "sm",
      "shadow": "sm",
      "hoverShadow": "lg",
      "border": true
    },
    "badges": {
      "borderRadius": "xs",
      "textTransform": "uppercase",
      "fontSize": "0.7rem",
      "fontWeight": 700
    },
    "inputs": {
      "borderRadius": "sm",
      "borderColor": "border",
      "focusRing": "accent"
    }
  }
}
