name = "my-storefront"
account_id = "your-cloudflare-account-id"
main = "src/index.tsx"
compatibility_date = "2025-01-01"
compatibility_flags = ["nodejs_compat"]
jsx_factory = "jsx"
jsx_fragment = "Fragment"

# Embed static assets as text modules
[[rules]]
type = "Text"
globs = ["**/*.css", "**/*.txt"]
fallthrough = false

[[kv_namespaces]]
binding = "CONTENT"
id = "your-kv-namespace-id"
preview_id = "your-kv-namespace-id"

[vars]
MAHO_API_URL = "https://your-maho-backend.example.com"
SYNC_SECRET = "generate-a-random-secret"
STORES = '[{"code":"default","name":"My Store","url":"https://store.example.com"}]'

# Optional: enable dev toolbar login/session system
# DEV_SECRET = "generate-a-random-secret"

# Optional: basic auth for the backend API (if required)
# MAHO_API_BASIC_AUTH = "user:password"

# Custom domain routing
# [[routes]]
# pattern = "store.example.com/*"
# zone_name = "example.com"
