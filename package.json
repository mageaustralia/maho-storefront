{
  "name": "maho-storefront",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run generate && npm run build:css && npm run build:js && wrangler dev --config wrangler.toml --local",
    "dev:watch": "npm run generate && (unocss \"src/**/*.{tsx,ts,js}\" --watch --out-file public/styles.css & esbuild src/js/app.js --bundle --format=esm --outfile=public/controllers.js.txt --external:https://cdn.jsdelivr.net/* --watch & wrangler dev --config wrangler.toml --local)",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.browser.json",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run",
    "build:js": "esbuild src/js/app.js --bundle --minify --format=esm --outfile=public/controllers.js.txt --external:https://cdn.jsdelivr.net/* && esbuild src/embed/embed.ts --bundle --minify --format=iife --outfile=public/embed.js.txt --target=es2020",
    "build:css": "unocss \"src/**/*.tsx\" \"src/**/*.ts\" \"src/**/*.js\" --minify --out-file public/styles.css",
    "build:css:legacy": "node scripts/build-theme.js",
    "generate": "node scripts/generate-store-registry.js && node scripts/generate-plugin-registry.js",
    "build": "npm run generate && npm run build:css && npm run build:js",
    "manifest": "node scripts/generate-manifest.js",
    "split-css": "node scripts/split-css.js",
    "docs:dev": "cd docs && npx vitepress dev",
    "docs:build": "cd docs && npx vitepress build"
  },
  "dependencies": {
    "hono": "^4.12.25",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20260207.0",
    "@hotwired/stimulus": "^3.2.2",
    "@unocss/cli": "^66.1.0",
    "@unocss/preset-typography": "^66.6.2",
    "daisyui": "^5.5.19",
    "esbuild": "^0.20.0",
    "typescript": "^5.9.3",
    "unocss": "^66.1.0",
    "vitest": "^4.0.18",
    "wrangler": "^4.63.0"
  }
}
